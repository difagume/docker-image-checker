# Conexión a Docker (opcional)
# Por defecto usa el socket del sistema:
#   - Windows: named pipe //./pipe/docker_engine
#   - Unix: /var/run/docker.sock
# Para usar TCP: tcp://host:port
DOCKER_HOST=

# GitHub Container Registry (opcional)
# Token con permiso read:packages para obtener información precisa de imágenes GHCR
GITHUB_GHCR_TOKEN=

# Autenticación htpasswd (opcional)
# Si esta variable está presente, se activa la autenticación
# Formato: username:$apr1$salt$hash
# Ejemplo con múltiples usuarios (separados por nueva línea):
# AUTH_HTPASSWD="admin:$apr1$salt$hash\nuser:$apr1$salt$hash2"
#
# Para generar un hash htpasswd, usa:
# htpasswd -nbm username password
#
# Ejemplo de credenciales (usuario: admin, password: admin123)
# AUTH_HTPASSWD="admin:$apr1$abc12345$X9Z8Y7W6V5U4T3S2R1Q0P"
#
# Password para encriptar cookies de sesión (mínimo 32 caracteres)
# Si no se define, se usará AUTH_HTPASSWD
# IMPORTANTE: Debe ser diferente a la contraseña del usuario para mayor seguridad
AUTH_SESSION_PASSWORD=
AUTH_HTPASSWD=

# Zona horaria para el scheduler de notificaciones
# Ejemplos: America/Guayaquil, Europe/Madrid, UTC
TZ=

# Notificaciones
# Habilitar/deshabilitar el sistema de notificaciones (por defecto: false)
NOTIFICATIONS_ENABLED=false

# Idioma para las notificaciones (por defecto: en)
# Opciones: en (English), es (Español), pt (Português)
# Si el usuario ha visitado el dashboard, se usará su idioma preferido automáticamente
NOTIFICATIONS_LANGUAGE=en

# Expresión cron para programar las verificaciones (por defecto: cada 6 horas)
# Formato: "minuto hora día mes día_semana"
# Ejemplos:
#   - "0 */6 * * *"  = Cada 6 horas
#   - "0 0 * * *"    = Diariamente a medianoche
#   - "0 */2 * * *"  = Cada 2 horas
#   - "*/30 * * * *" = Cada 30 minutos
NOTIFICATIONS_CRON_SCHEDULE=0 */6 * * *

# Telegram
# Para obtener el bot token: habla con @BotFather en Telegram
# Para obtener el chat ID: habla con @userinfobot en Telegram
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ntfy (https://ntfy.sh)
# Topic: nombre único para tu canal de notificaciones
# Server: servidor ntfy (por defecto: https://ntfy.sh)
# Autenticación: usa token O username/password (no ambos)
NTFY_ENABLED=false
NTFY_TOPIC=
NTFY_SERVER=https://ntfy.sh
NTFY_USERNAME=
NTFY_PASSWORD=
NTFY_TOKEN=

# Discord
# Para obtener webhook URL: Server Settings > Integrations > Webhooks > New Webhook
DISCORD_ENABLED=false
DISCORD_WEBHOOK_URL=

